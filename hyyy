<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PAP Printing</title>

<style>
:root {
    --primary:#06142e;
    --glass: rgba(255,255,255,0.08);
    --glass-border: rgba(255,255,255,0.15);
    --accent:#3b82f6;
    --text:#e2e8f0;
}

* {
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI', sans-serif;
}

body {
    background:var(--primary);
    color:white;
    overflow-x:hidden;
}

/* HEADER */
header {
    position:sticky;
    top:0;
    z-index:1000;
    background:rgba(6,20,46,0.6);
    backdrop-filter:blur(15px);
    border-bottom:1px solid var(--glass-border);
    padding:15px 60px;
}

nav {
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo {
    color:var(--accent);
    font-size:22px;
    font-weight:bold;
}

nav a {
    color:var(--text);
    margin-left:25px;
    text-decoration:none;
    cursor:pointer;
}

nav a:hover {
    color:var(--accent);
}

/* SECTIONS */
.section {
    display:none;
    padding:80px 60px;
    min-height:100vh;
}

.section.active {
    display:block;
}

/* ================= HOME ================= */
.hero {
    display:flex;
    flex-direction:column;
    align-items:center;
    text-align:center;
    gap:25px;

    padding:60px;
    border-radius:20px;

    background:var(--glass);
    border:1px solid var(--glass-border);
    backdrop-filter:blur(20px);
}

.hero p {
    color:var(--text);
    line-height:1.7;
    max-width:800px;
    opacity:0;
    transform:scale(0.9) translateY(20px);
    animation:popUp 0.8s forwards;
}

.hero p:nth-of-type(1){animation-delay:0.3s;}
.hero p:nth-of-type(2){animation-delay:0.6s;}
.hero p:nth-of-type(3){animation-delay:0.9s;}

@keyframes popUp {
    to {
        opacity:1;
        transform:scale(1) translateY(0);
    }
}

.hero h1 {
    font-size:52px;
}

.hero-images img {
    width:420px;
    height:260px;
    object-fit:cover;
    border-radius:16px;
    border:1px solid var(--glass-border);
}

/* STATS */
.stats {
    display:flex;
    justify-content:center;
    gap:60px;
    margin-top:50px;
}

.stats div {
    background:var(--glass);
    border:1px solid var(--glass-border);
    padding:20px;
    border-radius:15px;
    text-align:center;
}

.stats h2 {
    color:var(--accent);
}

/* ================= SERVICES ================= */
#services h2 {
    text-align:center;
    font-size:36px;
    margin-bottom:40px;
    color:var(--accent);
}

.services {
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:30px;
}

.service {
    position:relative;
    padding:35px 25px;
    border-radius:18px;
    background:rgba(255,255,255,0.06);
    border:1px solid var(--glass-border);
    backdrop-filter:blur(15px);
    transition:0.4s ease;
}

.service:hover {
    transform:translateY(-10px) scale(1.02);
    border-color:var(--accent);
}

.service::after {
    content:"";
    position:absolute;
    top:0;
    left:20px;
    width:40px;
    height:4px;
    background:var(--accent);
    border-radius:10px;
}

/* ================= WORK ================= */
.client {
    position:relative;
    overflow:hidden;
    transition:0.4s ease;
}

.client:hover {
    transform:translateY(-12px) scale(1.03);
    border-color:var(--accent);
}

/* WHATSAPP */
.whatsapp {
    position:fixed;
    bottom:25px;
    right:25px;
    width:60px;
    height:60px;
    background:#25D366;
    display:flex;
    align-items:center;
    justify-content:center;
    border-radius:50%;
    font-size:28px;
    color:white;
    text-decoration:none;
    box-shadow:0 10px 25px rgba(0,0,0,0.4);
}

/* FOOTER */
footer {
    background:#000;
    padding:50px 60px;
    margin-top:60px;
}

.footer-content {
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:30px;
}

footer h3 {
    color:var(--accent);
    margin-bottom:10px;
}

footer p {
    color:#cbd5e1;
    line-height:1.6;
}

/* ================= NEW CONTACT (UPDATED ONLY) ================= */
#contact h2 {
    text-align:center;
    font-size:40px;
    color:var(--accent);
    margin-bottom:10px;
}

#contact .subtitle {
    text-align:center;
    color:var(--text);
    max-width:700px;
    margin:0 auto 40px auto;
    line-height:1.6;
}

.contact-grid {
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

/* contact cards */
.contact-card {
    background:var(--glass);
    border:1px solid var(--glass-border);
    border-radius:18px;
    padding:30px 25px;
    text-align:center;
    backdrop-filter:blur(15px);
    transition:0.4s;
    position:relative;
    overflow:hidden;
}

.contact-card:hover {
    transform:translateY(-10px);
    border-color:var(--accent);
}

/* glow effect */
.contact-card::before {
    content:"";
    position:absolute;
    width:200%;
    height:200%;
    top:-50%;
    left:-50%;
    background:radial-gradient(circle, rgba(59,130,246,0.2), transparent 60%);
    opacity:0;
    transition:0.4s;
}

.contact-card:hover::before {
    opacity:1;
}

.contact-card h3 {
    margin-bottom:10px;
    color:white;
}

.contact-card p {
    color:var(--text);
    margin-bottom:10px;
}

.contact-card a {
    color:#25D366;
    font-weight:bold;
    text-decoration:none;
}

.contact-card a:hover {
    text-decoration:underline;
}

/* RESPONSIVE */
@media(max-width:900px){
    .stats {
        flex-direction:column;
        gap:20px;
    }
}
</style>
</head>

